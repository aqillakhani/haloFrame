# Supabase (provision a fresh project for HaloFrame)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Public-facing values for the mobile app (exposed via app.config.ts -> extra)
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# fal.ai
# -----------------------------------------------------------------------------
FAL_KEY=key_id:key_secret

# -----------------------------------------------------------------------------
# RevenueCat
# -----------------------------------------------------------------------------
REVENUECAT_SECRET_KEY=sk_xxxxxxxxxxxx
REVENUECAT_WEBHOOK_AUTH_HEADER=Bearer <shared-secret>
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Stripe (web + print checkout — Phase F)
# Create products in the Stripe dashboard, then paste price IDs here. See
# docs/SETUP.md §2 for the exact product list.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Subscriptions
STRIPE_PRICE_KEEPSAKE=price_xxx
STRIPE_PRICE_HERITAGE_MONTHLY=price_xxx
STRIPE_PRICE_HERITAGE_ANNUAL=price_xxx

# Top-ups
STRIPE_PRICE_TOPUP_SINGLE=price_xxx
STRIPE_PRICE_TOPUP_4PACK=price_xxx

# Canvas prints
STRIPE_PRICE_CANVAS_12X16=price_xxx
STRIPE_PRICE_CANVAS_18X24=price_xxx
STRIPE_PRICE_CANVAS_24X36=price_xxx
STRIPE_PRICE_CANVAS_36X48=price_xxx

# -----------------------------------------------------------------------------
# Print-order fulfillment (Phase F)
# When unset, the API logs the would-be email to stderr. When set, sends via
# Resend. See docs/SETUP.md §3.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM=orders@haloframe.app
ORDER_NOTIFICATION_EMAIL=aqil.lakhani8@gmail.com

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
EXPO_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
POSTHOG_API_KEY=phc_xxxxxxxxxxxx
EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxxxxxxxxxxx
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
API_PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS — comma-separated allowed origins. For local dev this is the Vite
# server; in prod, list your web domain(s).
CORS_ORIGINS=http://localhost:5187

# -----------------------------------------------------------------------------
# Router mode
# -----------------------------------------------------------------------------
# SPIKE_MODE=true  → only /api/spike/* (stateless AI proxy) is mounted.
#                    Quick iteration path with no DB state writes.
# SPIKE_MODE=false → /api/tribute, /api/templates, /api/print are ALSO mounted
#                    (requires Supabase). This is the production mode.
# The spike router is always mounted so both the test harness and prod can
# share the AI-quality pipeline. Default to false in prod-like envs.
SPIKE_MODE=false

# Web-side router toggle. `prod` (default) → list/delete/save hit /api/tribute.
# `spike` → the bridge to /api/tribute is disabled and the app behaves like
# the original stateless harness (useful for AI-only local iteration).
VITE_API_MODE=prod

# Stub print provider notification target (Phase 4 — manual fulfillment alerts)
PRINT_ALERT_WEBHOOK_URL=
PRINT_ALERT_EMAIL=

# -----------------------------------------------------------------------------
# Dev-only credit bypass
# -----------------------------------------------------------------------------
# When true, skips ALL credit checks: checkCredits, spendCredits, and the
# free-tier per-flow gate. The UI snapshot reports a high pseudo-balance so
# the merge/apply buttons stay enabled. Intended for local iteration where
# you don't want to keep topping up your test account.
#
# IGNORED in production (NODE_ENV=production) so an accidental commit of
# `DEV_UNLIMITED_CREDITS=true` to a prod env never grants free fal.ai calls
# to real users. Leave unset (or =false) for any real environment.
DEV_UNLIMITED_CREDITS=false

# -----------------------------------------------------------------------------
# Merge: skip pristine-main silhouette restore
# -----------------------------------------------------------------------------
# Legacy merge path composites the original main back over NB2's output
# everywhere outside the loved-one silhouette ("pristine passthrough"). This
# guarantees byte-perfect family preservation but creates a visible boundary
# wherever NB2 painted hair wisps, ambient shadows, or hallucinated extras —
# they get hard-clipped at the silhouette edge ("box around the loved one").
#
# Setting MERGE_SKIP_RESTORE=true uses NB2's raw output as the final image
# instead. Family fidelity then relies on the prompt's "preserve every
# existing person UNCHANGED" clause. The trade is: smoother integration of
# the loved one vs. byte-perfect family pixels. Empirically the simplified
# path matches direct-NB2 quality (the user's reference) while running ~10s
# faster.
#
# Defaults to false (legacy behavior) so existing setups don't change.
MERGE_SKIP_RESTORE=false

# -----------------------------------------------------------------------------
# Supabase Personal Access Token (Claude Code MCP only — not used by api/web)
# -----------------------------------------------------------------------------
# Used by the project-scoped Supabase MCP server defined in `.mcp.json`. The
# server is named `supabase-haloframe` and pinned to project
# `uqbckeyoclbhqntawsrz`. Generate a PAT at:
#   https://supabase.com/dashboard/account/tokens
# Scope: anything with access to the haloFrame org. Keep it out of git.
SUPABASE_PAT_HALOFRAME=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
