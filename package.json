{
  "name": "haloframe",
  "private": true,
  "version": "0.1.0",
  "description": "HaloFrame — AI memorial photo & tribute app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:shared": "npm run build --workspace=@haloframe/shared",
    "dev:api": "npm run dev --workspace=@haloframe/api",
    "dev:web": "npm run dev --workspace=@haloframe/web",
    "dev": "concurrently -n api,web -c blue,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "spike:sam3": "npm run spike:sam3 --workspace=@haloframe/api",
    "spike:templates": "npm run spike:templates --workspace=@haloframe/api",
    "spike:merge": "npm run spike:merge --workspace=@haloframe/api"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
